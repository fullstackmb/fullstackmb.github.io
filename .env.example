# Copy to .env for local overrides. .env is gitignored.

# Overrides the events iCal feed URL (default: https://www.meetup.com/fullstackmb/events/ical/)
#EVENTS_ICAL_URL=https://www.meetup.com/fullstackmb/events/ical/

# Trust a local ASP.NET Core dev cert, e.g. when pointing board/sponsors/slack calls
# at a local backend (see: dotnet dev-certs https --export-path)
#NODE_EXTRA_CA_CERTS=/home/you/.aspnet/https/devcert.pem
